# Flask configurations
SECRET_KEY=your-super-secret-key-here-change-this
USE_HTTPS=false

# Database configurations
# Leave blank to use local SQLite (default). Set to use PostgreSQL in production.
# DATABASE_URL=postgresql://user:password@localhost:5432/downloader_db
DATABASE_URL=

# Supabase Auth configuration (Crucial for SaaS features)
# Leave blank to fallback to local database authentication.
SUPABASE_URL=
SUPABASE_ANON_KEY=
